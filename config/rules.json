{
  "blacklist": ["BOMEUSDT"],
  "default_sort": {
    "key": "grid_score",
    "direction": "desc"
  },
  "filters": [
    {
      "field": "quote_volume",
      "label": "Min Quote Volume",
      "type": "number",
      "mode": "gte",
      "default": 50000000,
      "min": 0,
      "max": 50000000000,
      "step": 1000000
    },
    {
      "field": "breakout_risk",
      "label": "Max Breakout Risk",
      "type": "slider",
      "mode": "lte",
      "default": 70,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "field": "grid_score",
      "label": "Min Grid Score",
      "type": "select",
      "mode": "gte",
      "default": 0,
      "options": [0, 40, 50, 60, 70]
    }
  ]
}
